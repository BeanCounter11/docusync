{
  "name": "docusync",
  "version": "0.1.0",
  "description": "Local-first CLI and GitHub Action that syncs documentation with code changes",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "docusync": "./dist/cli/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/cli",
    "action.yml",
    "docusync.schema.json",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "build:action": "ncc build src/action/index.ts -o dist --source-map --license licenses.txt",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "documentation",
    "docs",
    "git",
    "llm",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.22",
    "@huggingface/transformers": "^3.4.2",
    "ai": "^4.3.16",
    "better-sqlite3": "^11.9.1",
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "minimatch": "^10.0.1",
    "picocolors": "^1.1.1",
    "ollama-ai-provider": "^1.2.0",
    "simple-git": "^3.27.0",
    "sqlite-vec": "^0.1.6",
    "zod": "^3.24.2",
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@vercel/ncc": "^0.38.3",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
